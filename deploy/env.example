# Copy to deploy/.env and fill in values (docker compose loads .env from the project directory
# when you run compose from repo root, or use `docker compose --env-file deploy/.env`).

# Required for the `litellm` Compose profile (proxy forwards to OpenAI).
OPENAI_API_KEY=

# Optional: must match what you pass as LITELLM_API_KEY to the harness (default: sk-anything).
# LITELLM_MASTER_KEY=sk-anything

# Optional interceptor trust-boundary keys. When set, callers must provide matching headers:
# X-Arbiter-Gateway-Key for intercept routes and X-Arbiter-Service-Key for verify/state routes.
# ARBITER_GATEWAY_SHARED_KEY=
# ARBITER_SERVICE_SHARED_KEY=

# Optional interceptor audit sink. When set, interceptor writes structured audit decisions
# to Postgres in addition to stdout logs.
# ARBITER_AUDIT_POSTGRES_DSN=postgres://arbiter:arbiter@postgres:5432/arbiter?sslmode=disable
# ARBITER_AUDIT_POSTGRES_QUEUE=2048

# Optional control-plane API protection key. When set, mutating control-plane APIs require:
# X-Arbiter-Control-Key header.
# CONTROL_PLANE_API_KEY=

# Bundle distribution service token used by OPA to fetch control-plane artifacts.
# Must match ARBITER_BUNDLE_SERVICE_TOKEN in compose/runtime.
# ARBITER_BUNDLE_SERVICE_TOKEN=dev-bundle-token
# ARBITER_BUNDLE_SERVICE_TOKEN_SCOPES=bundle:read
